# Required - Get from Discord: Server Settings > Integrations > Webhooks > New Webhook
DISCORD_WEBHOOK=https://discord.com/api/webhooks/1234567890/abcdefghijklmnop

# SKUs to monitor (comma-separated, no spaces)
# Find SKU in Best Buy product URL: /site/.../6571900.p
BESTBUY_SKUS=6571900,6571897

# Store IDs (comma-separated)
# 138 = Pinole, CA | 135 = Pleasant Hill, CA | 324 = Emeryville, CA | 482 = San Francisco, CA
BESTBUY_STORES=138,135

# How often to check stock (seconds, min 30)
CHECK_INTERVAL=60

# How long before re-alerting same item at same store (minutes)
COOLDOWN_MINUTES=30

# How often to send a heartbeat/health-check Discord message (seconds)
HEALTH_CHECK_INTERVAL=1800

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Where to persist cooldown state (survives restarts)
STATE_FILE=state.json
